PORT=3000
DATABASE_URL=postgresql://smartpig:smartpig@localhost:5432/smartpig?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=2592000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# DeFindex
DEFINDEX_API_KEY=
DEFINDEX_BASE_URL=
DEFINDEX_TIMEOUT_MS=10000
DEFINDEX_NETWORK=testnet

REDIS_URL=redis://localhost:6379

# BlindPay (on/off-ramp BRL/PIX)
BLINDPAY_API_KEY=
BLINDPAY_INSTANCE_ID=
BLINDPAY_BASE_URL=https://api.blindpay.com
BLINDPAY_WEBHOOK_SECRET=
BLINDPAY_TOKEN=

# Etherfuse (on/off-ramp MXN/CLABE — Stellar)
# Sandbox: crie conta em https://devnet.etherfuse.com → Ramp → API Keys
# Produção: crie conta em https://app.etherfuse.com → Ramp → API Keys
# IMPORTANTE: Não use prefixo "Bearer" — a key é enviada diretamente no header Authorization
ETHERFUSE_API_KEY=
# Sandbox: https://api.sand.etherfuse.com | Produção: https://api.etherfuse.com
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
# Gerado ao criar um webhook via POST /ramp/webhook na API Etherfuse
# Retornado APENAS UMA VEZ no campo "secret" da resposta — armazene imediatamente
ETHERFUSE_WEBHOOK_SECRET=

# Stellar
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_USDC_ASSET_CODE=USDC
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Optional. Configure both values to include this trustline during activation.
STELLAR_TESOURO_ASSET_CODE=
STELLAR_TESOURO_ISSUER=
# Maximum inclusion fee per operation paid by Treasury. Soroban resource fees
# from the simulated inner transaction are preserved automatically.
STELLAR_FEE_BUMP_BASE_FEE=500
STELLAR_FEE_BUMP_MULTIPLIER=2

# Privy (wallet-based auth)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Treasury (sponsored Stellar account activation)
# Stellar secret key of the treasury account that sponsors reserves for new user wallets
TREASURY_STELLAR_SECRET=

# Vaults (comma-separated list of IDs to show in the app)
ALLOWED_VAULT_IDS=cmoz2caya000m4fzcaug219yh
