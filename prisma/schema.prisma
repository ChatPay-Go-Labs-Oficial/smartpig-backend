// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum IntentStatus {
  CREATED
  XDR_GENERATED
  SIGNED_XDR_RECEIVED
  SUBMITTED
  CONFIRMED
  FAILED
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum IntentType {
  DEPOSIT
  WITHDRAWAL
}

enum ManagedVaultStatus {
  PENDING_SIGNATURE
  SUBMITTED
  CONFIRMED
  FAILED
}

enum RampStatus {
  PENDING
  AWAITING_PAYMENT
  PROCESSING
  DELEGATION_NEEDED
  COMPLETED
  FAILED
  REFUNDED
}

enum EtherfuseKycStatus {
  NOT_STARTED
  PROPOSED
  APPROVED
  APPROVED_CHAIN_DEPLOYING
  REJECTED
}

enum EtherfuseOrderDirection {
  ONRAMP
  OFFRAMP
}

enum EtherfuseOrderStatus {
  CREATED
  PENDING_SIGNATURE
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String?   @unique
  name      String?
  avatarUrl String?
  googleId    String?  @unique
  appleId     String?  @unique
  isOnboarded Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets           WalletAccount[]
  depositIntents    DepositIntent[]
  withdrawalIntents WithdrawalIntent[]
  transactions      TransactionRecord[]
  portfolioSnapshots PortfolioSnapshot[]
  refreshTokens     RefreshToken[]
  auditLogs         ApiAuditLog[]
  managedVaults     ManagedVault[]
  blindpayReceiver  BlindPayReceiver?
  onrampTxns        OnrampTransaction[]
  offrampTxns       OfframpTransaction[]
  etherfuseCustomer EtherfuseCustomer?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// Wallets
// ─────────────────────────────────────────────

model WalletAccount {
  id             String   @id @default(cuid())
  userId         String
  stellarAddress String   @unique
  label          String?
  isActive       Boolean  @default(true)
  isActivated    Boolean  @default(false)
  createdAt      DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositIntents    DepositIntent[]
  withdrawalIntents WithdrawalIntent[]

  @@index([userId])
  @@map("wallet_accounts")
}

// ─────────────────────────────────────────────
// Vaults
// ─────────────────────────────────────────────

model VaultCatalog {
  id               String   @id @default(cuid())
  defindexVaultId  String   @unique
  name             String
  assetSymbol      String
  description      String?
  apy              Decimal? @db.Decimal(10, 4)
  tvl              Decimal? @db.Decimal(30, 8)
  metadata         Json?
  isActive         Boolean  @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  depositIntents    DepositIntent[]
  withdrawalIntents WithdrawalIntent[]
  portfolioSnapshots PortfolioSnapshot[]
  managedVault      ManagedVault?

  @@index([isActive])
  @@map("vault_catalog")
}

// ─────────────────────────────────────────────
// Deposit Intents
// ─────────────────────────────────────────────

model DepositIntent {
  id              String        @id @default(cuid())
  idempotencyKey  String        @unique
  userId          String
  walletAccountId String
  vaultId         String
  amount          Decimal       @db.Decimal(30, 8)
  assetSymbol     String
  status          IntentStatus  @default(CREATED)
  unsignedXdr     String?       @db.Text
  signedXdr       String?       @db.Text
  errorMessage    String?
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id])
  vault         VaultCatalog  @relation(fields: [vaultId], references: [id])
  transaction   TransactionRecord?

  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("deposit_intents")
}

// ─────────────────────────────────────────────
// Withdrawal Intents
// ─────────────────────────────────────────────

model WithdrawalIntent {
  id              String        @id @default(cuid())
  idempotencyKey  String        @unique
  userId          String
  walletAccountId String
  vaultId         String
  shareAmount     Decimal       @db.Decimal(30, 8)
  status          IntentStatus  @default(CREATED)
  unsignedXdr     String?       @db.Text
  signedXdr       String?       @db.Text
  errorMessage    String?
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id])
  vault         VaultCatalog  @relation(fields: [vaultId], references: [id])
  transaction   TransactionRecord?

  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("withdrawal_intents")
}

// ─────────────────────────────────────────────
// Transactions
// ─────────────────────────────────────────────

model TransactionRecord {
  id                 String            @id @default(cuid())
  userId             String
  intentType         IntentType
  depositIntentId    String?           @unique
  withdrawalIntentId String?           @unique
  txHash             String?           @unique
  status             TransactionStatus @default(PENDING)
  blockchainResponse Json?
  createdAt          DateTime          @default(now())
  confirmedAt        DateTime?

  user             User              @relation(fields: [userId], references: [id])
  depositIntent    DepositIntent?    @relation(fields: [depositIntentId], references: [id])
  withdrawalIntent WithdrawalIntent? @relation(fields: [withdrawalIntentId], references: [id])

  @@index([userId])
  @@index([txHash])
  @@index([status])
  @@map("transaction_records")
}

// ─────────────────────────────────────────────
// Portfolio
// ─────────────────────────────────────────────

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  userId        String
  vaultId       String
  balanceAmount Decimal  @db.Decimal(30, 8)
  balanceUsd    Decimal? @db.Decimal(20, 4)
  capturedAt    DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id])
  vault VaultCatalog @relation(fields: [vaultId], references: [id])

  @@index([userId, capturedAt])
  @@index([vaultId, capturedAt])
  @@map("portfolio_snapshots")
}

// ─────────────────────────────────────────────
// Vault Manager (SmartPig-owned vaults)
// ─────────────────────────────────────────────

model ManagedVault {
  id                    String             @id @default(cuid())
  creatorUserId         String
  callerAddress         String
  name                  String
  symbol                String
  description           String?
  vaultFeeBps           Int                @default(25)
  roles                 Json
  assets                Json
  status                ManagedVaultStatus @default(PENDING_SIGNATURE)
  unsignedXdr           String?            @db.Text
  signedXdr             String?            @db.Text
  predictedVaultAddress String?
  txHash                String?            @unique
  vaultCatalogId        String?            @unique
  errorMessage          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  creator      User          @relation(fields: [creatorUserId], references: [id], onDelete: Cascade)
  vaultCatalog VaultCatalog? @relation(fields: [vaultCatalogId], references: [id])

  @@index([creatorUserId])
  @@index([status])
  @@map("managed_vaults")
}

// ─────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────

model ApiAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  userAgent  String?
  payload    Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, resource])
  @@map("api_audit_logs")
}

// ─────────────────────────────────────────────
// BlindPay On/Off Ramp
// ─────────────────────────────────────────────

model BlindPayReceiver {
  id                 String   @id @default(cuid())
  userId             String   @unique
  blindpayReceiverId String   @unique
  name               String
  taxId              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts      BlindPayBankAccount[]
  blockchainWallets BlindPayBlockchainWallet[]
  onrampTxns        OnrampTransaction[]
  offrampTxns       OfframpTransaction[]

  @@map("blindpay_receivers")
}

model BlindPayBankAccount {
  id                    String  @id @default(cuid())
  receiverId            String
  blindpayBankAccountId String  @unique
  type                  String
  pixKey                String?
  isDefault             Boolean @default(false)

  createdAt DateTime @default(now())

  receiver    BlindPayReceiver     @relation(fields: [receiverId], references: [id], onDelete: Cascade)
  offrampTxns OfframpTransaction[]

  @@index([receiverId])
  @@map("blindpay_bank_accounts")
}

model BlindPayBlockchainWallet {
  id               String @id @default(cuid())
  receiverId       String
  blindpayWalletId String @unique
  network          String
  address          String

  createdAt DateTime @default(now())

  receiver   BlindPayReceiver    @relation(fields: [receiverId], references: [id], onDelete: Cascade)
  onrampTxns OnrampTransaction[]

  @@index([receiverId])
  @@map("blindpay_blockchain_wallets")
}

model OnrampTransaction {
  id                 String     @id @default(cuid())
  idempotencyKey     String     @unique
  userId             String
  receiverId         String
  blockchainWalletId String
  blindpayPayinId    String?    @unique
  blindpayQuoteId    String?
  amountBrl          Decimal    @db.Decimal(20, 2)
  amountUsdc         Decimal?   @db.Decimal(20, 6)
  pixCode            String?    @db.Text
  status             RampStatus @default(PENDING)
  errorMessage       String?
  completedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user             User                     @relation(fields: [userId], references: [id])
  receiver         BlindPayReceiver         @relation(fields: [receiverId], references: [id])
  blockchainWallet BlindPayBlockchainWallet @relation(fields: [blockchainWalletId], references: [id])

  @@index([userId, status])
  @@index([blindpayPayinId])
  @@map("onramp_transactions")
}

model OfframpTransaction {
  id                    String     @id @default(cuid())
  idempotencyKey        String     @unique
  userId                String
  receiverId            String
  bankAccountId         String
  blindpayPayoutId      String?    @unique
  blindpayQuoteId       String?
  amountUsdc            Decimal    @db.Decimal(20, 6)
  amountBrl             Decimal?   @db.Decimal(20, 2)
  senderWalletAddress   String
  unsignedDelegationXdr String?    @db.Text
  signedDelegationHash  String?
  status                RampStatus @default(PENDING)
  errorMessage          String?
  completedAt           DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  receiver    BlindPayReceiver    @relation(fields: [receiverId], references: [id])
  bankAccount BlindPayBankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([userId, status])
  @@index([blindpayPayoutId])
  @@map("offramp_transactions")
}

// ─────────────────────────────────────────────
// Etherfuse Ramps
// ─────────────────────────────────────────────

model EtherfuseCustomer {
  id             String             @id @default(cuid())
  userId         String             @unique
  etherfuseOrgId String             @unique
  kycStatus      EtherfuseKycStatus @default(NOT_STARTED)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts EtherfuseBankAccount[]
  orders       EtherfuseOrder[]

  @@map("etherfuse_customers")
}

model EtherfuseBankAccount {
  id              String   @id @default(cuid())
  customerId      String
  etherfuseBankId String   @unique
  // SPEI (Mexico)
  clabe           String?
  // PIX (Brazil)
  pixKey          String?
  pixKeyType      String?
  rail            String   @default("spei") // "spei" | "pix"
  accountType     String
  isCompliant     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer EtherfuseCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   EtherfuseOrder[]

  @@index([customerId])
  @@map("etherfuse_bank_accounts")
}

model EtherfuseOrder {
  id                String                  @id @default(cuid())
  idempotencyKey    String                  @unique
  customerId        String
  bankAccountId     String
  etherfuseOrderId  String?                 @unique
  etherfuseQuoteId  String
  direction         EtherfuseOrderDirection
  status            EtherfuseOrderStatus    @default(CREATED)
  sourceAsset       String
  targetAsset       String
  sourceAmount      Decimal                 @db.Decimal(30, 8)
  destinationAmount Decimal                 @db.Decimal(30, 8)
  walletAddress     String
  unsignedBurnXdr   String?                 @db.Text
  signedBurnXdr     String?                 @db.Text
  errorMessage      String?
  completedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  customer    EtherfuseCustomer    @relation(fields: [customerId], references: [id])
  bankAccount EtherfuseBankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([customerId, status])
  @@map("etherfuse_orders")
}
